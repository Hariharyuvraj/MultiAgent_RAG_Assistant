# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# Groq — get your key at console.groq.com (free tier available)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini — optional, console.cloud.google.com
GOOGLE_API_KEY=your_google_api_key_here

# HuggingFace — optional, huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# Active providers — must match config/settings.yaml
LLM_PROVIDER=groq
EMBEDDING_PROVIDER=huggingface
